# papertrade-india — example environment configuration.
#
# Copy to `.env` and fill in only what you need. EVERYTHING here is
# OPTIONAL: with no keys set, the broker uses the free providers
# (yfinance -> jugaad) and works out of the box. Keys unlock live
# broker feeds and higher-rate data sources.

# ─────────────────────────────────────────────────────────────────────
# Live broker feeds (real bid/ask + market depth)
# ─────────────────────────────────────────────────────────────────────

# Upstox — recommended live feed. Any NSE symbol resolves automatically.
# Use the 1-year "Analytics" token (Developer Apps -> Analytics tab), not
# the daily OAuth token, for an always-on setup.
UPSTOX_ACCESS_TOKEN=

# Dhan — alternative live feed (needs a symbol -> security_id map).
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# Zerodha Kite — live feed (market data is a paid Kite Connect add-on).
# The access token rotates daily.
KITE_API_KEY=
KITE_ACCESS_TOKEN=

# ─────────────────────────────────────────────────────────────────────
# Optional data-provider API keys (delayed / EOD sources)
# ─────────────────────────────────────────────────────────────────────

ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=
FINNHUB_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# Safety
# ─────────────────────────────────────────────────────────────────────

# Set to 1 to hard-block all order placement (global kill switch).
PAPERTRADE_INDIA_KILL_SWITCH=0
